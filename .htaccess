Options -Indexes -MultiViews

RewriteEngine On
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
RewriteRule ^api/lead$ /api/lead.php [L]
RewriteRule ^api/chat$ /api/chat.php [L]
RewriteRule ^api/cms/(content|session|history|undo|restore|upload)$ /api/cms.php?action=$1 [L,QSA]
RewriteRule ^editor/?$ /editor.php [L]

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

<FilesMatch "^relay\.php$">
  Require all denied
</FilesMatch>
